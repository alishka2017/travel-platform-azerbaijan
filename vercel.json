{
  "security": {
    "checkpoint": {
      "enabled": true,
      "excludedPaths": [
        "/cities/*",
        "/visa",
        "/visa/*",
        "/itineraries/*",
        "/hidden-gems",
        "/hidden-gems/*"
      ]
    }
  },
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "installCommand": "npm install",
  "env": {
    "NEXT_PUBLIC_SITE_URL": "https://smartholiday.az"
  }
}